<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body class="bg-light">

<%- include('partials/header') %>

<div class="container py-5">

  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
      <h1 class="display-6 fw-bold mb-1">Últimos Posts</h1>
      <p class="text-muted mb-0">Leia os artigos mais recentes.</p>
    </div>
    <a href="/criar" class="btn btn-dark">
      <i class="bi bi-plus-circle me-2"></i>Escrever Post
    </a>
  </div>

  <hr class="mb-4">

  <% if (posts.length === 0) { %>
    <div class="alert alert-info text-center">
      <i class="bi bi-info-circle me-2"></i>Nenhum post publicado ainda. Seja o primeiro!
    </div>
  <% } %>

  <div class="row g-4">
    <% posts.forEach(post => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border-0">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-semibold"><%= post.title %></h5>
            <p class="card-text text-muted flex-grow-1">
              <%= post.content.length > 120 ? post.content.substring(0, 120) + '...' : post.content %>
            </p>
            <div class="mt-3">
              <small class="text-muted d-block mb-3">
                <i class="bi bi-calendar3 me-1"></i>
                <%= new Date(post.createdAt).toLocaleDateString('pt-BR') %>
              </small>
              <div class="d-flex gap-2 flex-wrap">
                <a href="/posts/<%= post.id %>" class="btn btn-dark btn-sm">
                  Ler mais <i class="bi bi-arrow-right ms-1"></i>
                </a>
                <a href="/editar/<%= post.id %>" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-pencil me-1"></i>Editar
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

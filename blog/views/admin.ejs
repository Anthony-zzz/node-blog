<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Painel Admin — Blog</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body class="bg-light">

<%- include('partials/header') %>

<div class="container py-5">

  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
      <h1 class="fw-bold mb-1">Painel de Posts</h1>
      <% if (isAdmin) { %>
        <span class="badge bg-success"><i class="bi bi-shield-check me-1"></i>Admin logado</span>
      <% } else { %>
        <span class="badge bg-secondary"><i class="bi bi-person me-1"></i>Visitante — <a href="/admin/login" class="text-white">entrar como admin</a></span>
      <% } %>
    </div>
    <a href="/criar" class="btn btn-dark">
      <i class="bi bi-plus-circle me-2"></i>Novo Post
    </a>
  </div>

  <% if (posts.length === 0) { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>Nenhum post cadastrado ainda.
    </div>
  <% } %>

  <% if (!isAdmin) { %>
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
      <i class="bi bi-exclamation-triangle me-2 fs-5"></i>
      <div>Você pode criar e editar posts. Para <strong>excluir</strong>, faça <a href="/admin/login">login como admin</a>.</div>
    </div>
  <% } %>

  <div class="row g-3">
    <% posts.forEach(post => { %>
      <div class="col-12">
        <div class="card shadow-sm border-0">
          <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
              <h5 class="card-title fw-semibold mb-1"><%= post.title %></h5>
              <small class="text-muted">
                <i class="bi bi-calendar3 me-1"></i>
                <%= new Date(post.createdAt).toLocaleDateString('pt-BR') %>
              </small>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <a href="/posts/<%= post.id %>" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-eye me-1"></i>Ver
              </a>
              <a href="/editar/<%= post.id %>" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Editar
              </a>
              <% if (isAdmin) { %>
                <form action="/admin/delete/<%= post.id %>" method="POST" class="m-0">
                  <button type="submit" class="btn btn-outline-danger btn-sm"
                    onclick="return confirm('Tem certeza que deseja excluir este post?')">
                    <i class="bi bi-trash me-1"></i>Excluir
                  </button>
                </form>
              <% } else { %>
                <button class="btn btn-outline-danger btn-sm" disabled title="Somente admin pode excluir">
                  <i class="bi bi-lock me-1"></i>Excluir
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

</div>

<%- include('partials/footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
